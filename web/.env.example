# Copy this file to .env and fill in real values for local development.
# On Railway, set these as Variables in the dashboard instead — no .env file
# is deployed there.

# Required for sign-in and transactions to work at all. Get this from your
# Clerk dashboard -> API Keys -> Secret key. NEVER commit this or paste it
# anywhere public — it lets someone impersonate any of your users.
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# The publishable key (safe to be public) is already hardcoded in
# public/index.html's Clerk <script> tag, since it's meant to ship to the
# browser. Only change it there if you switch to a different Clerk app.

# Copy to .env for local Postgres, or leave unset to use the local JSON store.
#
# When DATABASE_URL is set, the app uses Postgres; otherwise it falls back to
# web/data/db.json. On Railway, set this to a reference to your Postgres plugin:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgres://user:password@localhost:5432/wikiclaim

# SSL handling is automatic (off for localhost / *.railway.internal, on otherwise).
# Override if needed: "true" forces SSL, "false" disables it.
# DATABASE_SSL=true

# Port to listen on. Railway sets this automatically.
# PORT=3000

# --- Resend (welcome + marketing email) ---
# Get this from your Resend dashboard -> API Keys. Without it, welcome
# emails and marketing-contact sync are silently skipped (a warning is
# logged on boot) - nothing else breaks.
RESEND_API_KEY=re_your_api_key_here

# Verified sender address in Resend (Domains -> your domain must be
# verified first). Friendly-name format works: "WikiPicks <hello@yourdomain.com>"
RESEND_FROM_EMAIL=WikiPicks <hello@yourdomain.com>

# The Segment (Resend's Audience page -> Segments) new signups get added to,
# so scripts/send-marketing.js has someone to send to. Optional - without
# it, welcome emails still work but contact sync is skipped.
RESEND_SEGMENT_ID=

# Optional: shown as a link in the welcome email. Leave unset to omit it.
# APP_URL=https://your-deployed-app.example.com

# --- Admin (escrow review) ---
# Any long random string you make up yourself (e.g. `openssl rand -hex 32`).
# Required to use /api/admin/escrow/* (reviewing holdings flagged by the
# anti-botting earnings cap, see contiguousSettlement in game.js). Without
# it, those routes are disabled entirely - a warning is logged on boot.
# Send it as an "X-Admin-Key" header on requests to those routes.
ADMIN_KEY=

# --- AI spike-check (Anthropic) ---
# Get this from the Anthropic Console -> API Keys. Without it, AI triage on
# flagged holdings (see spike-check.js) is silently disabled - a warning is
# logged on boot, flagging/escrow itself still works, reviewers just see no
# AI read on /api/admin/escrow.
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
