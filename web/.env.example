# Copy to .env for local Postgres, or leave unset to use the local JSON store.
#
# When DATABASE_URL is set, the app uses Postgres; otherwise it falls back to
# web/data/db.json. On Railway, set this to a reference to your Postgres plugin:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgres://user:password@localhost:5432/wikiclaim

# SSL handling is automatic (off for localhost / *.railway.internal, on otherwise).
# Override if needed: "true" forces SSL, "false" disables it.
# DATABASE_SSL=true

# Port to listen on. Railway sets this automatically.
# PORT=3000
